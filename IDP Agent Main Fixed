    "    twitterLink: Optional[str] = Field(None)\n",
    "    linkedinLink: Optional[str] = Field(None)\n",
    "    instagramLink: Optional[str] = Field(None)\n",
    "    logo: Optional[str] = Field(None)\n",
    "    address_line1: Optional[str] = Field(None)\n",
