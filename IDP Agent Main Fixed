    "import json, os\n",
    "from langchain_community.vectorstores import FAISS\n",
    "from langchain_community.embeddings import DatabricksEmbeddings\n",
    "from langchain_core.documents import Document\n",
    "\n",
    "# Guard: load from disk if all_results not in memory (e.g. after kernel restart)\n",
    "if 'all_results' not in dir() or not all_results:\n",
    "    if os.path.exists(RESULTS_JSON_PATH):\n",
    "        with open(RESULTS_JSON_PATH) as f:\n",
    "            all_results = json.load(f)\n",
    "        print(f\"Loaded {len(all_results)} results from {RESULTS_JSON_PATH}\")\n",
    "    else:\n",
    "        raise RuntimeError(\"No extraction results found. Run the full extraction cell first.\")\n",
    "\n",
    "docs = []\n",
    "for r in all_results:\n",
    "    facts = r.get('facts', {})\n",
    "    content = f\"\"\"Facility: {r['name']}\n",
    "City: {r.get('city','') or ''}\n",
    "Region: {r.get('region','') or ''}\n",
    "Country: {r.get('country','Ghana') or 'Ghana'}\n",
    "Type: {r.get('facility_type','') or ''}\n",
    "Org Type: {r.get('org_type','') or ''}\n",
    "Specialties: {', '.join(r.get('specialties', []))}\n",
    "Capabilities: {', '.join(facts.get('capability', []))}\n",
    "Procedures: {', '.join(facts.get('procedure', []))}\n",
    "Equipment: {', '.join(facts.get('equipment', []))}\n",
    "Description: {r.get('description','') or ''}\n",
    "Operator: {r.get('operator_type','') or ''}\n",
    "Affiliations: {', '.join(r.get('affiliations', []) or [])}\n",
    "Anomalies: {', '.join(r.get('anomalies', []))}\n",
    "Confidence: {r.get('confidence', 0)}\"\"\".strip()\n",
    "\n",
    "    docs.append(Document(\n",
    "        page_content=content,\n",
    "        metadata={\n",
    "            \"name\": str(r.get('name','')),\n",
