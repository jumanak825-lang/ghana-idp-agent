    "        mlflow.log_param(\"org_type_classified\", org_type)\n",
    "        mlflow.log_text(json.dumps(s1, indent=2), \"stage1_org_classification.json\")\n",
    "\n",
    "        # ── Stage 2: Structured fields ───────────────────────────────\n",
    "        s2_prompt = (\n",
    "            ORGANIZATION_INFORMATION_SYSTEM_PROMPT.format(organization=name)\n",
    "            + \"\\n\\nText:\\n\" + input_text\n",
    "            + \"\"\"\\n\\nRespond ONLY with valid JSON:\n",
    "{\"name\":\"\",\"phone_numbers\":[],\"officialPhone\":\"\",\"email\":\"\",\n",
    "\"websites\":[],\"officialWebsite\":\"\",\"yearEstablished\":null,\n",
    "\"acceptsVolunteers\":null,\"facebookLink\":\"\",\"twitterLink\":\"\",\n",
    "\"linkedinLink\":\"\",\"instagramLink\":\"\",\"logo\":\"\",\n",
    "\"address_line1\":\"\",\"address_line2\":\"\",\"address_line3\":\"\",\n",
    "\"address_city\":\"\",\"address_stateOrRegion\":\"\",\"address_zipOrPostcode\":\"\",\n",
    "\"address_country\":\"\",\"address_countryCode\":\"\",\n",
    "\"facilityTypeId\":\"\",\"operatorTypeId\":\"\",\"affiliationTypeIds\":[],\n",
    "\"description\":\"\",\"area\":null,\"numberDoctors\":null,\"capacity\":null,\n",
    "\"countries\":[],\"missionStatement\":\"\",\"missionStatementLink\":\"\",\n",
    "\"organizationDescription\":\"\"}\"\"\"\n",
    "        )\n",
    "        s2 = parse_json(llm.invoke(s2_prompt).content)\n",
    "        mlflow.log_text(json.dumps(s2, indent=2), \"stage2_org_fields.json\")\n",
    "\n",
    "        # ── Stage 3: Free-form facts ──────────────────────────────────\n",
    "        s3_prompt = (\n",
    "            FREE_FORM_SYSTEM_PROMPT.format(organization=name)\n",
    "            + \"\\n\\nContent:\\n\" + input_text\n",
    "            + '\\n\\nRespond ONLY with valid JSON (no markdown):\\n{\"procedure\":[],\"equipment\":[],\"capability\":[]}'\n",
    "        )\n",
    "        s3 = parse_json(llm.invoke(s3_prompt).content)\n",
    "        facts = FacilityFacts(\n",
    "            procedure=s3.get(\"procedure\", []),\n",
    "            equipment=s3.get(\"equipment\", []),\n",
    "            capability=s3.get(\"capability\", [])\n",
    "        )\n",
    "        mlflow.log_text(json.dumps(s3, indent=2), \"stage3_free_form_facts.json\")\n",
    "        mlflow.log_metric(\"procedures_extracted\", len(facts.procedure or []))\n",
    "        mlflow.log_metric(\"equipment_extracted\", len(facts.equipment or []))\n",
    "        mlflow.log_metric(\"capabilities_extracted\", len(facts.capability or []))\n",
    "\n",
    "        # ── Stage 4: Medical specialties ──────────────────────────────\n",
    "        s4_prompt = (\n",
    "            MEDICAL_SPECIALTIES_SYSTEM_PROMPT.format(organization=name)\n",
    "            + \"\\n\\nContent:\\n\" + input_text\n",
    "        )\n",
    "        s4 = parse_json(llm.invoke(s4_prompt).content)\n",
    "        specialties = MedicalSpecialties(specialties=s4.get(\"specialties\", []))\n",
    "        mlflow.log_text(json.dumps(s4, indent=2), \"stage4_specialties.json\")\n",
    "        mlflow.log_metric(\"specialties_extracted\", len(specialties.specialties or []))\n",
    "\n",
    "        # ── Anomaly detection ─────────────────────────────────────────\n",
    "        anomalies = []\n",
    "        proc_count  = len(facts.procedure or [])\n",
    "        equip_count = len(facts.equipment or [])\n",
    "        cap_count   = len(facts.capability or [])\n",
    "        facility_type = s2.get(\"facilityTypeId\") or str(row.get('facilityTypeId',''))\n",
    "        all_caps  = \" \".join(facts.capability or []).lower()\n",
    "        all_specs = \" \".join(specialties.specialties or []).lower()\n",
    "\n",
    "        if facility_type == \"clinic\" and proc_count > 10:\n",
    "            anomalies.append(f\"Q4.4: Clinic claims {proc_count} procedures — unrealistically high\")\n",
    "        if proc_count > 5 and equip_count == 0:\n",
    "            anomalies.append(f\"Q4.8: Claims {proc_count} procedures but zero equipment documented\")\n",
    "        if \"icu\" in all_caps and equip_count == 0:\n",
    "            anomalies.append(\"Q4.9: Claims ICU capability but no supporting equipment listed\")\n",
    "        if \"surgery\" in all_caps and equip_count == 0:\n",
    "            anomalies.append(\"Q4.9: Claims surgical capability but no operating equipment documented\")\n",
    "        advanced = [\"cardiology\",\"cardiacsurgery\",\"neurosurgery\",\"orthopedicsurgery\"]\n",
    "        if any(s in all_specs for s in advanced) and equip_count == 0:\n",
    "            anomalies.append(\"Q3.1: Claims advanced specialty but no supporting equipment found\")\n",
    "\n",
    "        # Confidence score\n",
    "        if equip_count > 0 and cap_count > 0 and proc_count > 0:\n",
    "            confidence = 0.95\n",
    "        elif cap_count > 0 and (equip_count > 0 or proc_count > 0):\n",
    "            confidence = 0.75\n",
    "        elif cap_count > 0 or proc_count > 0:\n",
    "            confidence = 0.55\n",
    "        else:\n",
    "            confidence = 0.30\n",
    "        if anomalies:\n",
    "            confidence = round(confidence * 0.8, 2)\n",
    "\n",
    "        mlflow.log_metric(\"confidence\", confidence)\n",
    "        mlflow.log_metric(\"anomaly_count\", len(anomalies))\n",
    "        mlflow.log_text(json.dumps(anomalies, indent=2), \"anomalies.json\")\n",
    "\n",
    "        # ── Final merged record ───────────────────────────────────────\n",
    "        result = {\n",
    "            \"name\": name,\n",
    "            \"org_type\": org_type,\n",
    "            \"row_id\": str(row.get('pk_unique_id','')),\n",
    "            \"unique_id\": str(row.get('unique_id','')),\n",
    "            \"source_url\": str(row.get('source_url','')),\n",
    "            \"city\": s2.get(\"address_city\") or str(row.get('address_city','')),\n",
    "            \"region\": s2.get(\"address_stateOrRegion\") or str(row.get('address_stateOrRegion','')),\n",
    "            \"country\": s2.get(\"address_country\") or str(row.get('address_country','Ghana')),\n",
    "            \"country_code\": s2.get(\"address_countryCode\") or str(row.get('address_countryCode','GH')),\n",
    "            \"facility_type\": s2.get(\"facilityTypeId\") or str(row.get('facilityTypeId','')),\n",
    "            \"operator_type\": s2.get(\"operatorTypeId\") or str(row.get('operatorTypeId','')),\n",
    "            \"affiliations\": s2.get(\"affiliationTypeIds\") or [],\n",
    "            \"description\": s2.get(\"description\") or str(row.get('description','')),\n",
    "            \"number_doctors\": s2.get(\"numberDoctors\") or row.get('numberDoctors'),\n",
    "            \"capacity\": s2.get(\"capacity\") or row.get('capacity'),\n",
    "            \"area\": s2.get(\"area\") or row.get('area'),\n",
    "            \"year_established\": s2.get(\"yearEstablished\") or row.get('yearEstablished'),\n",
    "            \"accepts_volunteers\": s2.get(\"acceptsVolunteers\"),\n",
    "            \"phone_numbers\": s2.get(\"phone_numbers\") or [],\n",
    "            \"email\": s2.get(\"email\") or str(row.get('email','')),\n",
    "            \"official_website\": s2.get(\"officialWebsite\") or str(row.get('officialWebsite','')),\n",
    "            \"facebook\": s2.get(\"facebookLink\") or str(row.get('facebookLink','')),\n",
    "            \"twitter\": s2.get(\"twitterLink\") or str(row.get('twitterLink','')),\n",
    "            \"linkedin\": s2.get(\"linkedinLink\") or str(row.get('linkedinLink','')),\n",
    "            \"instagram\": s2.get(\"instagramLink\") or str(row.get('instagramLink','')),\n",
