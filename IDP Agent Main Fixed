    "import pandas as pd\n",
    "\n",
    "def clean_columns(df):\n",
    "    \"\"\"Consistent column cleaning used everywhere in this notebook.\"\"\"\n",
    "    df.columns = [\n",
    "        col.replace(' ', '_').replace(';','').replace('{','').replace('}','')\n",
    "           .replace('(','').replace(')','').replace('\\n','').replace('\\t','')\n",
    "           .replace('=','').replace('/','_').replace('.','_')\n",
    "        for col in df.columns\n",
    "    ]\n",
    "    return df\n",
    "\n",
    "# Verify CSV exists before proceeding\n",
    "import os\n",
    "if not os.path.exists(CSV_PATH):\n",
    "    raise FileNotFoundError(\n",
    "        f\"CSV not found at: {CSV_PATH}\\n\"\n",
    "        \"Please update the csv_path widget at the top of this notebook.\"\n",
