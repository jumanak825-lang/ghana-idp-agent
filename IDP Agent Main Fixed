    "            context += \"\\n\".join([f\"- {r['region']}: score={r['score']}\" for r in sorted(critical, key=lambda x: x['score'])[:10]])\n",
    "            prompt = f\"Global health advisor for Ghana.\\n{context}\\nQuestion: {question}\\nProvide specific recommendations.\"\n",
    "            return self.llm.invoke(prompt).content\n",
    "\n",
