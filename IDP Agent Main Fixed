    "def genie_agent(question: str) -> str:\n",
    "    \"\"\"\n",
    "    Converts natural language questions to Databricks SQL and queries ghana_facilities.\n",
    "    Answers: Q1.1, Q1.2, Q1.5, Q4.7, Q7.5, Q7.6, Q8.3\n",
    "    \"\"\"\n",
    "    schema = \"\"\"\n",
    "    Table: ghana_facilities\n",
    "    Columns:\n",
    "    - name (string): facility name\n",
    "    - facilityTypeId (string): hospital, clinic, dentist, pharmacy, doctor\n",
    "    - operatorTypeId (string): public, private\n",
    "    - affiliationTypeIds (string): faith-tradition, philanthropy-legacy, community, academic, government\n",
    "    - address_city (string): city\n",
    "    - address_stateOrRegion (string): region\n",
    "    - address_country (string): country\n",
    "    - specialties (string): JSON array stored as string e.g. '[\"cardiology\",\"internalMedicine\"]'\n",
    "    - procedure (string): JSON array as string\n",
    "    - equipment (string): JSON array as string\n",
    "    - capability (string): JSON array as string\n",
    "    - numberDoctors (integer): number of doctors\n",
    "    - capacity (integer): bed capacity\n",
    "    - organization_type (string): facility or ngo\n",
    "    - description (string): facility description\n",
    "    \"\"\"\n",
    "\n",
    "    sql_prompt = f\"\"\"You are a SQL expert for a Databricks Delta Lake healthcare database.\n",
    "\n",
    "{schema}\n",
    "\n",
    "Question: {question}\n",
    "\n",
    "CRITICAL DATABRICKS SQL RULES:\n",
    "- NEVER use JSON_EXTRACT, JSON_VALUE, or any JSON functions\n",
    "- For JSON array columns use LIKE: specialties LIKE '%cardiology%'\n",
    "- For case-insensitive matching use LOWER()\n",
    "- Always add LIMIT 50 unless counting total\n",
    "- facilityTypeId values: hospital, clinic, dentist, pharmacy, doctor\n",
    "- organization_type values: facility, ngo\n",
    "- Return ONLY the SQL query, no markdown fences\n",
    "\"\"\"\n",
    "\n",
    "    sql_raw = llm.invoke(sql_prompt).content.strip()\n",
    "    if \"```sql\" in sql_raw:\n",
    "        sql_raw = sql_raw.split(\"```sql\")[1].split(\"```\")[0].strip()\n",
    "    elif \"```\" in sql_raw:\n",
    "        sql_raw = sql_raw.split(\"```\")[1].split(\"```\")[0].strip()\n",
    "\n",
    "    try:\n",
    "        result_df = spark.sql(sql_raw).toPandas()\n",
    "        if len(result_df) == 0:\n",
    "            return \"No results found for this query.\"\n",
    "\n",
    "        interpret_prompt = f\"\"\"Question: {question}\n",
    "\n",
    "SQL Query Used:\n",
    "{sql_raw}\n",
    "\n",
    "Results:\n",
    "{result_df.to_string(index=False)}\n",
    "\n",
    "Provide a clear concise answer. Include specific numbers and facility names.\n",
    "Note any medically significant patterns.\"\"\"\n",
    "\n",
    "        answer = llm.invoke(interpret_prompt).content\n",
    "        return f\"{answer}\\n\\n\uD83D\uDCCA SQL: `{sql_raw}`\"\n",
    "\n",
    "    except Exception as e:\n",
    "        return f\"Query error: {str(e)}\\nSQL attempted: {sql_raw}\"\n",
    "\n",
    "# Quick test\n",
    "print(\"Genie test — Q1.5:\")\n",
    "print(genie_agent(\"Which region has the most hospitals?\")[:400])\n",
