    "import mlflow\n",
    "import json\n",
    "import logging\n",
    "\n",
    "logger = logging.getLogger(\"idp_agent\")\n",
    "\n",
    "def parse_json(text: str) -> dict:\n",
    "    \"\"\"Parse JSON from LLM output, stripping markdown fences and whitespace.\"\"\"\n",
    "    text = text.strip()\n",
    "    # Strip markdown fences\n",
    "    if \"```json\" in text:\n",
    "        text = text.split(\"```json\")[1].split(\"```\")[0].strip()\n",
    "    elif \"```\" in text:\n",
    "        text = text.split(\"```\")[1].split(\"```\")[0].strip()\n",
    "    # Remove any leading/trailing non-JSON characters\n",
    "    start = text.find('{')\n",
    "    end   = text.rfind('}')\n",
    "    if start != -1 and end != -1:\n",
    "        text = text[start:end+1]\n",
    "    try:\n",
    "        return json.loads(text)\n",
    "    except Exception as e:\n",
    "        logger.warning(f\"JSON parse failed: {e} | raw: {text[:200]}\")\n",
    "        return {}\n",
    "\n",
    "def clean_val(v):\n",
    "    if str(v) in ['nan','None','NaN','null','']:\n",
    "        return None\n",
    "    return v\n",
    "\n",
    "def build_input_text(row: dict) -> str:\n",
    "    fields = [\n",
    "        'source_url','name','specialties','procedure','equipment',\n",
    "        'capability','organization_type','phone_numbers','email',\n",
    "        'websites','officialWebsite','yearEstablished','acceptsVolunteers',\n",
    "        'facebookLink','twitterLink','linkedinLink','instagramLink',\n",
    "        'address_line1','address_line2','address_line3','address_city',\n",
    "        'address_stateOrRegion','address_zipOrPostcode','address_country',\n",
    "        'address_countryCode','countries','missionStatement',\n",
    "        'missionStatementLink','organizationDescription','facilityTypeId',\n",
    "        'operatorTypeId','affiliationTypeIds','description','area',\n",
    "        'numberDoctors','capacity'\n",
    "    ]\n",
    "    parts = []\n",
    "    for field in fields:\n",
    "        val = str(row.get(field, ''))\n",
    "        if val not in ['nan','None','null','[]','','NaN']:\n",
    "            parts.append(f\"{field}: {val}\")\n",
    "    return \"\\n\".join(parts)\n",
    "\n",
    "def extract_facility_vf(row: dict) -> dict | None:\n",
    "    \"\"\"\n",
    "    Full 4-stage extraction pipeline:\n",
    "      Stage 1: Org classification (NGO vs Facility)\n",
    "      Stage 2: Structured field extraction\n",
    "      Stage 3: Free-form facts (procedure / equipment / capability)\n",
    "      Stage 4: Medical specialty classification\n",
    "      + Anomaly detection\n",
    "    \"\"\"\n",
    "    name = str(row.get('name', 'Unknown'))\n",
    "    input_text = build_input_text(row)\n",
    "    if not input_text.strip():\n",
    "        return None\n",
    "\n",
    "    with mlflow.start_run(run_name=f\"extract_{str(row.get('pk_unique_id','?'))}\", nested=True):\n",
    "        mlflow.log_param(\"facility_name\", name[:100])\n",
    "        mlflow.log_param(\"city\", str(row.get('address_city',''))[:50])\n",
    "        mlflow.log_param(\"region\", str(row.get('address_stateOrRegion',''))[:50])\n",
    "        mlflow.log_param(\"org_type_csv\", str(row.get('organization_type','')))\n",
    "        mlflow.log_param(\"source_url\", str(row.get('source_url',''))[:200])\n",
    "        mlflow.log_text(input_text, \"input_text.txt\")\n",
    "\n",
    "        # ── Stage 1: Org classification ──────────────────────────────\n",
    "        s1_prompt = (\n",
    "            ORGANIZATION_EXTRACTION_SYSTEM_PROMPT\n",
    "            + \"\\n\\nText to classify:\\n\" + input_text\n",
    "            + '\\n\\nRespond ONLY with valid JSON:\\n{\"ngos\": [], \"facilities\": [], \"other_organizations\": []}'\n",
    "        )\n",
    "        s1 = parse_json(llm.invoke(s1_prompt).content)\n",
