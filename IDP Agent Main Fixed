    "\n",
    "Answer the question with specific numbers and facility names where relevant.\"\"\"\n",
    "\n",
    "        return self.llm.invoke(prompt).content\n",
    "\n",
    "    def vector_search(self, question):\n",
    "        q = question.lower()\n",
    "        keywords = [w for w in q.split() if len(w) > 3]\n",
    "\n",
    "        matches = []\n",
    "        for r in self.all_results:\n",
    "            score = 0\n",
    "            text = (\n",
    "                str(r.get('name','')) + ' ' +\n",
    "                str(r.get('city','')) + ' ' +\n",
    "                str(r.get('region','')) + ' ' +\n",
    "                str(r.get('facility_type','')) + ' ' +\n",
    "                str(r.get('specialties',[])) + ' ' +\n",
    "                str(r.get('facts',{}).get('capability',[])) + ' ' +\n",
    "                str(r.get('facts',{}).get('procedure',[])) + ' ' +\n",
    "                str(r.get('description',''))\n",
    "            ).lower()\n",
    "            for kw in keywords:\n",
    "                if kw in text:\n",
    "                    score += 1\n",
    "            if score > 0:\n",
    "                matches.append((score, r))\n",
    "\n",
    "        matches.sort(key=lambda x: x[0], reverse=True)\n",
    "        top = [r for _, r in matches[:5]]\n",
    "\n",
    "        if not top:\n",
    "            return f\"No facilities found matching: {question}\"\n",
    "\n",
    "        context = \"\\n\\n\".join([\n",
    "            f\"Facility: {r['name']}\\nCity: {r.get('city','')}\\nType: {r.get('facility_type','')}\\n\"\n",
    "            f\"Specialties: {r.get('specialties',[])}\\nCapabilities: {r.get('facts',{}).get('capability',[])}\\n\"\n",
    "            f\"Procedures: {r.get('facts',{}).get('procedure',[])}\"\n",
    "            for r in top\n",
    "        ])\n",
    "\n",
    "        prompt = f\"Question: {question}\\n\\nFacility data:\\n{context}\\n\\nAnswer specifically citing facility names.\"\n",
    "        return self.llm.invoke(prompt).content\n",
    "\n",
    "    def geospatial_agent(self, question):\n",
    "        from geopy.distance import geodesic\n",
    "        q = question.lower()\n",
    "        if any(w in q for w in ['cold spot','desert','gap','absent']):\n",
    "            critical = self.scores_df[self.scores_df['desert_score'] < 20].sort_values('desert_score')\n",
    "            at_risk  = self.scores_df[(self.scores_df['desert_score'] >= 20) & (self.scores_df['desert_score'] < 50)]\n",
    "            return f\"\"\"\uD83D\uDDFA️ Geographic Cold Spot Analysis for Ghana\n",
    "\uD83D\uDD34 CRITICAL ({len(critical)} regions): {', '.join(critical['region'].head(5).tolist())}\n",
    "\uD83D\uDFE1 AT RISK ({len(at_risk)} regions): {', '.join(at_risk['region'].head(5).tolist())}\n",
    "Worst region: {critical.iloc[0]['region']} (score: {critical.iloc[0]['desert_score']}/100)\"\"\"\n",
    "\n",
    "        extracted = self.parse_json(self.llm.invoke(\n",
    "            f'Extract: distance_km, location, specialty from: \"{question}\"\\nJSON only: {{\"distance_km\":50,\"location\":\"Tamale\",\"specialty\":\"cardiology\"}}'\n",
    "        ).content)\n",
    "        distance_km = extracted.get('distance_km', 50)\n",
