    "    df['description'].apply(lambda x: str(x) not in ['nan','None','']) |\n",
    "    df['procedure'].apply(lambda x: str(x) not in ['[]','null','nan',''])\n",
    "].reset_index(drop=True)\n",
    "\n",
    "print(f\"Total facilities to process: {len(has_data)}\")\n",
    "\n",
    "# Resume from checkpoint if exists\n",
    "if os.path.exists(RESULTS_JSON_PATH):\n",
    "    with open(RESULTS_JSON_PATH) as f:\n",
    "        all_results = json.load(f)\n",
    "    print(f\"♻️ Resuming from checkpoint: {len(all_results)} already extracted\")\n",
    "else:\n",
    "    all_results = []\n",
    "    print(\"\uD83C\uDD95 Starting fresh extraction\")\n",
    "\n",
    "already_done = {r['row_id'] for r in all_results}\n",
    "errors = 0\n",
    "\n",
    "mlflow.set_experiment(MLFLOW_EXPERIMENT)\n",
    "\n",
    "with mlflow.start_run(run_name=\"VF_Full_Extraction\"):\n",
