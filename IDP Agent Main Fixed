    "import mlflow\n",
    "import mlflow.pyfunc\n",
    "from mlflow.models.signature import ModelSignature\n",
    "from mlflow.models.rag_signatures import ChatCompletionRequest, ChatCompletionResponse\n",
    "from databricks.sdk import WorkspaceClient\n",
    "from databricks.sdk.service.serving import ServedEntityInput, EndpointCoreConfigInput\n",
    "import json, os, shutil\n",
    "\n",
    "MLFLOW_EXPERIMENT  = \"/Users/23f2001749@ds.study.iitm.ac.in/Ghana_IDP_Agent\"\n",
    "WORKSPACE_BASE     = \"/Workspace/Users/23f2001749@ds.study.iitm.ac.in/ghana_idp_outputs\"\n",
    "RESULTS_JSON_PATH  = f\"{WORKSPACE_BASE}/vf_extracted_results.json\"\n",
    "SCORES_CSV_PATH    = f\"{WORKSPACE_BASE}/desert_scores.csv\"\n",
    "UC_MODEL_NAME      = \"workspace.default.ghana_idp_agent\"\n",
    "\n",
    "token = dbutils.notebook.entry_point.getDbutils().notebook().getContext().apiToken().get()\n",
    "host  = dbutils.notebook.entry_point.getDbutils().notebook().getContext().apiUrl().get()\n",
    "\n",
    "mlflow.set_registry_uri(\"databricks-uc\")\n",
    "mlflow.set_experiment(MLFLOW_EXPERIMENT)\n",
    "\n",
    "# ── Bundle data files ──────────────────────────────────────────────────\n",
    "artifacts_dir = \"/tmp/ghana_idp_artifacts\"\n",
    "os.makedirs(artifacts_dir, exist_ok=True)\n",
    "\n",
    "shutil.copy(RESULTS_JSON_PATH, f\"{artifacts_dir}/vf_extracted_results.json\")\n",
    "shutil.copy(SCORES_CSV_PATH,   f\"{artifacts_dir}/desert_scores.csv\")\n",
    "\n",
    "print(\"✅ Data files bundled:\")\n",
    "print(f\"   results : {os.path.getsize(artifacts_dir+'/vf_extracted_results.json')//1024}KB\")\n",
    "print(f\"   scores  : {os.path.getsize(artifacts_dir+'/desert_scores.csv')//1024}KB\")\n",
    "\n",
    "class GhanaIDPAgent(mlflow.pyfunc.PythonModel):\n",
    "\n",
    "    def load_context(self, context):\n",
    "        import json, pandas as pd\n",
    "        from langchain_databricks import ChatDatabricks\n",
    "\n",
    "        results_path = context.artifacts[\"results_json\"]\n",
    "        scores_path  = context.artifacts[\"scores_csv\"]\n",
    "\n",
    "        self.llm = ChatDatabricks(\n",
    "            endpoint=\"databricks-meta-llama-3-3-70b-instruct\",\n",
    "            max_tokens=1000, temperature=0\n",
    "        )\n",
    "\n",
    "        with open(results_path) as f:\n",
    "            self.all_results = json.load(f)\n",
    "\n",
    "        self.scores_df = pd.read_csv(scores_path)\n",
    "\n",
    "        self.city_coords = {\n",
    "            'accra': (5.6037,-0.1870), 'kumasi': (6.6885,-1.6244),\n",
    "            'takoradi': (4.9016,-1.7833), 'tamale': (9.4034,-0.8424),\n",
    "            'cape coast': (5.1053,-1.2466), 'koforidua': (6.0940,-0.2592),\n",
    "            'sunyani': (7.3349,-2.3123), 'wa': (10.0601,-2.5099),\n",
    "            'bolgatanga': (10.7856,-0.8514), 'ho': (6.6011,0.4712),\n",
    "            'techiman': (7.5920,-1.9350), 'tema': (5.6698,-0.0166),\n",
    "            'tepa': (7.0000,-2.5000), 'weija': (5.5833,-0.3167),\n",
    "            'akosombo': (6.2997,-0.0589), 'dompoase': (6.5000,-1.6167),\n",
    "            'duayaw nkwanta': (7.3500,-2.3500), 'abesim': (7.4000,-2.3000),\n",
    "        }\n",
    "        print(f\"✅ Agent loaded: {len(self.all_results)} facilities\")\n",
    "\n",
    "    def parse_json(self, text):\n",
    "        import json\n",
    "        text = text.strip()\n",
    "        if \"```json\" in text:\n",
    "            text = text.split(\"```json\")[1].split(\"```\")[0].strip()\n",
    "        elif \"```\" in text:\n",
    "            text = text.split(\"```\")[1].split(\"```\")[0].strip()\n",
    "        start, end = text.find('{'), text.rfind('}')\n",
    "        if start != -1 and end != -1:\n",
    "            text = text[start:end+1]\n",
    "        try:\n",
    "            return json.loads(text)\n",
    "        except:\n",
    "            return {}\n",
    "\n",
    "    def route_question(self, q):\n",
    "        q = q.lower()\n",
    "        if any(w in q for w in ['km','kilometer','distance','within','nearest','cold spot','radius']):\n",
    "            return 'geospatial'\n",
    "        if any(w in q for w in ['anomal','unrealistic','breadth','no equipment','suspicious','misrepresent']):\n",
    "            return 'anomaly'\n",
    "        if any(w in q for w in ['what services','tell me about','services does','clinics in','which clinic','are there any']):\n",
    "            return 'vector_search'\n",
    "        if any(w in q for w in ['workforce','practitioners','ngo','ngos','where should','invest','recommend']):\n",
    "            return 'medical_reasoning'\n",
    "        if any(w in q for w in ['plan','allocate','strategy','roadmap']):\n",
    "            return 'planning'\n",
    "        return 'genie'\n",
    "\n",
    "    def genie_agent(self, question):\n",
    "        import pandas as pd\n",
    "\n",
    "        df = pd.DataFrame([{\n",
    "            'name': r.get('name',''),\n",
    "            'facilityTypeId': r.get('facility_type',''),\n",
    "            'operatorTypeId': r.get('operator_type',''),\n",
    "            'address_stateOrRegion': r.get('region',''),\n",
    "            'address_city': r.get('city',''),\n",
    "            'specialties': str(r.get('specialties',[])),\n",
    "            'procedure': str(r.get('facts',{}).get('procedure',[])),\n",
    "            'equipment': str(r.get('facts',{}).get('equipment',[])),\n",
    "            'capability': str(r.get('facts',{}).get('capability',[])),\n",
    "            'numberDoctors': r.get('number_doctors',''),\n",
    "            'capacity': r.get('capacity',''),\n",
    "            'organization_type': r.get('org_type',''),\n",
    "        } for r in self.all_results])\n",
    "\n",
    "        q = question.lower()\n",
    "        keywords = [w for w in q.split() if len(w) > 3]\n",
    "\n",
    "        filtered = df\n",
    "        for kw in keywords:\n",
    "            mask = df.apply(lambda row: row.astype(str).str.lower().str.contains(kw).any(), axis=1)\n",
    "            if mask.sum() > 0:\n",
    "                filtered = df[mask]\n",
    "                break\n",
    "\n",
    "        sample = filtered.head(30).to_string(index=False)\n",
    "\n",
    "        prompt = f\"\"\"You are a data analyst for Ghana healthcare facilities.\n",
    "\n",
    "Question: {question}\n",
    "\n",
    "Available data ({len(df)} total facilities, showing relevant sample):\n",
    "{sample}\n",
    "\n",
    "Summary stats:\n",
    "- Total facilities: {len(df)}\n",
    "- Hospitals: {len(df[df['facilityTypeId']=='hospital'])}\n",
    "- Clinics: {len(df[df['facilityTypeId']=='clinic'])}\n",
