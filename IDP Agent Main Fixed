    "            if city in location or location in city:\n",
    "                target = coords\n",
    "                break\n",
    "        if not target:\n",
    "            return f\"Could not find coordinates for: {location}\"\n",
    "\n",
    "        nearby = []\n",
    "        for r in self.all_results:\n",
    "            city_val = str(r.get('city','') or '').lower()\n",
    "            fac_coords = None\n",
    "            for city_name, coords in self.city_coords.items():\n",
    "                if city_name in city_val or city_val in city_name:\n",
    "                    fac_coords = coords\n",
    "                    break\n",
    "            if not fac_coords: continue\n",
    "            dist = geodesic(target, fac_coords).km\n",
    "            if dist <= distance_km:\n",
    "                specs = [s.lower() for s in r.get('specialties', [])]\n",
    "                if specialty and not any(specialty in s for s in specs): continue\n",
    "                nearby.append({'name': r['name'], 'city': r.get('city',''), 'dist': round(dist,1)})\n",
    "\n",
    "        if not nearby:\n",
    "            all_spec = [r for r in self.all_results if specialty and specialty in [s.lower() for s in r.get('specialties',[])]]\n",
    "            msg = f\"⚠️ No {specialty} facilities within {distance_km}km of {location}.\\n\"\n",
    "            if all_spec:\n",
    "                locs = list(set(r.get('city') or r.get('region','?') for r in all_spec))\n",
    "                msg += f\"\uD83D\uDD34 Critical Gap — {len(all_spec)} {specialty} facilities exist but all are in: {', '.join(locs[:5])}\"\n",
    "            return msg\n",
    "\n",
    "        nearby.sort(key=lambda x: x['dist'])\n",
    "        return f\"Found {len(nearby)} facilities within {distance_km}km of {location}:\\n\" + \\\n",
    "               \"\\n\".join([f\"• {f['name']} — {f['city']} — {f['dist']}km\" for f in nearby[:10]])\n",
    "\n",
    "    def anomaly_agent(self, question):\n",
    "        anomaly_facs = [r for r in self.all_results if r.get('anomalies')]\n",
