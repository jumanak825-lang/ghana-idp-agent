    "import json, os\n",
    "import folium\n",
    "import pandas as pd\n",
    "from collections import defaultdict\n",
    "\n",
    "WORKSPACE_BASE    = \"/Workspace/Users/23f2001749@ds.study.iitm.ac.in/ghana_idp_outputs\"\n",
    "FAISS_PATH        = f\"{WORKSPACE_BASE}/faiss_index\"\n",
    "RESULTS_JSON_PATH = f\"{WORKSPACE_BASE}/vf_extracted_results.json\"\n",
    "SCORES_CSV_PATH   = f\"{WORKSPACE_BASE}/desert_scores.csv\"\n",
    "MAP_HTML_PATH     = f\"{WORKSPACE_BASE}/ghana_medical_desert_map.html\"\n",
    "os.makedirs(WORKSPACE_BASE, exist_ok=True)\n",
    "\n",
    "# Guard: reload if needed\n",
    "if 'all_results' not in dir() or not all_results:\n",
    "    with open(RESULTS_JSON_PATH) as f:\n",
    "        all_results = json.load(f)\n",
    "    print(f\"♻️ Reloaded {len(all_results)} results from disk\")\n",
    "\n",
    "region_data = defaultdict(lambda: {\n",
    "    'facilities': 0, 'hospitals': 0, 'clinics': 0, 'ngos': 0,\n",
    "    'specialties': set(), 'has_emergency': False,\n",
    "    'equipment_count': 0, 'procedure_count': 0,\n",
    "    'anomalies': 0, 'total_confidence': 0,\n",
    "    'facility_names': []\n",
    "})\n",
    "\n",
    "for r in all_results:\n",
    "    region = str(r.get('region') or r.get('city') or 'Unknown')\n",
    "    if region in ['nan','None','']:\n",
    "        region = 'Unknown'\n",
    "    rd = region_data[region]\n",
    "    rd['facilities'] += 1\n",
    "    rd['facility_names'].append(r.get('name',''))\n",
    "    if r.get('facility_type') == 'hospital':  rd['hospitals'] += 1\n",
    "    if r.get('facility_type') == 'clinic':    rd['clinics']  += 1\n",
    "    if r.get('org_type') == 'ngo':            rd['ngos']     += 1\n",
    "    for s in r.get('specialties', []):\n",
    "        rd['specialties'].add(s)\n",
    "    if 'emergencyMedicine' in r.get('specialties', []):\n",
    "        rd['has_emergency'] = True\n",
    "    facts = r.get('facts', {})\n",
    "    rd['equipment_count']   += len(facts.get('equipment', []))\n",
    "    rd['procedure_count']   += len(facts.get('procedure', []))\n",
    "    rd['anomalies']         += len(r.get('anomalies', []))\n",
    "    rd['total_confidence']  += r.get('confidence', 0)\n",
    "\n",
    "scores = []\n",
    "for region, data in region_data.items():\n",
    "    if region == 'Unknown': continue\n",
    "    score = 0\n",
    "    score += min(data['hospitals'] * 3, 25)\n",
    "    score += min(len(data['specialties']) * 2, 20)\n",
    "    score += 20 if data['has_emergency'] else 0\n",
    "    score += min(data['equipment_count'], 15)\n",
    "    score += min(data['facilities'], 20)\n",
    "    score = min(score, 100)\n",
    "    avg_conf = data['total_confidence'] / max(data['facilities'], 1)\n",
    "    scores.append({\n",
    "        'region': region,\n",
    "        'desert_score': score,\n",
    "        'facilities': data['facilities'],\n",
    "        'hospitals': data['hospitals'],\n",
    "        'clinics': data['clinics'],\n",
    "        'ngos': data['ngos'],\n",
    "        'specialties': list(data['specialties']),\n",
    "        'specialty_count': len(data['specialties']),\n",
    "        'has_emergency': data['has_emergency'],\n",
    "        'equipment_count': data['equipment_count'],\n",
    "        'procedure_count': data['procedure_count'],\n",
    "        'anomalies': data['anomalies'],\n",
    "        'avg_confidence': round(avg_conf, 2),\n",
    "        'risk': '\uD83D\uDD34 CRITICAL' if score < 20 else ('\uD83D\uDFE1 AT RISK' if score < 50 else '\uD83D\uDFE2 ADEQUATE')\n",
    "    })\n",
    "\n",
    "scores_df = pd.DataFrame(scores).sort_values('desert_score')\n",
    "print(\"=== MEDICAL DESERT SCORES ===\")\n",
    "print(scores_df[['region','desert_score','facilities','hospitals','has_emergency','risk']].to_string(index=False))\n",
    "\n",
    "scores_df.to_csv(SCORES_CSV_PATH, index=False)\n",
    "print(f\"\\n✅ Desert scores saved to {SCORES_CSV_PATH}\")\n",
    "\n",
    "region_coords = {\n",
    "    'Greater Accra': (5.6037,-0.1870), 'Ashanti': (6.7470,-1.5209),\n",
    "    'Western': (5.1315,-2.0412), 'Central': (5.5502,-1.0711),\n",
    "    'Eastern': (6.5522,-0.4610), 'Volta': (6.5722,0.4490),\n",
    "    'Northern': (9.5409,-0.9056), 'Upper East': (10.7551,-0.9056),\n",
    "    'Upper West': (10.2529,-2.3284), 'Bono': (7.9408,-2.3284),\n",
    "    'Ahafo': (7.3490,-2.3640), 'Bono East': (7.7500,-1.0500),\n",
    "    'Oti': (7.9000,0.3000), 'Savannah': (9.0820,-1.7148),\n",
    "    'North East': (10.5000,-0.3667), 'Western North': (6.3000,-2.7000),\n",
    "    'Accra': (5.6037,-0.1870), 'Kumasi': (6.6885,-1.6244),\n",
    "    'Takoradi': (4.9016,-1.7833), 'Tamale': (9.4034,-0.8424),\n",
    "}\n",
    "region_coords_norm = {k.lower().replace(' region','').strip(): v for k,v in region_coords.items()}\n",
    "\n",
    "ghana_map = folium.Map(location=[7.9465,-1.0232], zoom_start=7, tiles='CartoDB positron')\n",
    "plotted = 0\n",
    "\n",
    "for _, row in scores_df.iterrows():\n",
    "    region = row['region']\n",
    "    norm = region.lower().replace(' region','').strip()\n",
    "    coords = region_coords.get(region) or region_coords_norm.get(norm)\n",
    "    if not coords:\n",
    "        for key, val in region_coords_norm.items():\n",
    "            if key in norm or norm in key:\n",
    "                coords = val\n",
    "                break\n",
    "    if not coords: continue\n",
    "\n",
    "    score = row['desert_score']\n",
    "    color  = 'red' if score < 20 else ('orange' if score < 50 else 'green')\n",
    "    radius = max(score / 6, 6)\n",
    "    popup_html = f\"\"\"\n",
    "    <div style='font-family:Arial;min-width:200px'>\n",
    "    <b style='font-size:14px'>{region}</b><br><hr style='margin:4px 0'>\n",
    "    <b>Desert Score: {score}/100</b><br><b>{row['risk']}</b><br><hr style='margin:4px 0'>\n",
    "    Facilities: {row['facilities']} | Hospitals: {row['hospitals']} | Clinics: {row['clinics']}<br>\n",
    "    NGOs: {row['ngos']} | Emergency: {'✅' if row['has_emergency'] else '❌'}<br>\n",
    "    Specialties: {row['specialty_count']} | Anomalies: {row['anomalies']}<br>\n",
    "    Avg Confidence: {row['avg_confidence']}\n",
    "    </div>\"\"\"\n",
    "    folium.CircleMarker(\n",
    "        location=coords, radius=radius, color=color,\n",
    "        fill=True, fill_color=color, fill_opacity=0.7,\n",
    "        popup=folium.Popup(popup_html, max_width=280),\n",
    "        tooltip=f\"{region}: {score}/100 {row['risk']}\"\n",
    "    ).add_to(ghana_map)\n",
    "    plotted += 1\n",
    "\n",
    "legend_html = \"\"\"\n",
    "<div style='position:fixed;bottom:30px;left:30px;z-index:1000;background:white;\n",
    "     padding:15px;border-radius:8px;border:2px solid #ccc;font-family:Arial;font-size:13px'>\n",
    "<b>\uD83C\uDFE5 Medical Desert Score</b><br><br>\n",
    "\uD83D\uDD34 CRITICAL (0–20)<br>\uD83D\uDFE0 AT RISK (20–50)<br>\uD83D\uDFE2 ADEQUATE (50–100)<br><br>\n",
    "<i>Circle size = score<br>Click for details</i>\n",
    "</div>\n",
    "\"\"\"\n",
    "ghana_map.get_root().html.add_child(folium.Element(legend_html))\n",
    "ghana_map.save(MAP_HTML_PATH)\n",
    "print(f\"✅ Map saved to {MAP_HTML_PATH} | Plotted {plotted} regions\")\n",
    "ghana_map"
   ]
