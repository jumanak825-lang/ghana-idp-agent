    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "from typing import List, Literal, Optional\n",
    "from pydantic import BaseModel, Field\n",
    "\n",
    "ORGANIZATION_EXTRACTION_SYSTEM_PROMPT = \"\"\"\n",
    "You are a healthcare classification expert.\n",
    "\n",
    "Task: Extract medical facilities and NGOs present in the text, sorted into their appropriate categories.\n",
    "\n",
    "Definitions\n",
    "- ngos: An NGO is any non-profit organization that delivers tangible, on-the-ground healthcare services in low- or lower-middle-income settings. This includes international organizations, foundations, and charitable institutions that provide direct medical care, health education, or medical infrastructure support. Organizations whose work is limited to advocacy, social services, cultural programs, higher education, mental-health-only initiatives, rehabilitation, or other non-clinical activities do not qualify. Look for organizations with terms like \"Foundation\", \"Trust\", \"Society\", \"Initiative\", \"Corporation\" (municipal), \"International\", \"Global\", \"Mission\", \"Relief\", \"Aid\", \"Care\", \"Health\", \"Medical\", \"Research Institute\" (if non-profit), and similar non-profit indicators.\n",
    "- facilities: A publishable healthcare facility is any physical site that is currently operating and delivers in-person medical diagnosis or treatment to patients. This includes hospitals, clinics, health centers, specialty practices, and medical centers. Administrative offices, research-only centers, supply warehouses, long-term custodial homes, virtual-only services, and other non-clinical sites do not qualify.\n",
    "\n",
    "Critical Requirements\n",
    "- ONLY extract organizations explicitly mentioned by NAME in the provided text. Do NOT add organizations not present in the source text.\n",
    "- Extract organization names consistently: always use complete unabbreviated form, do NOT include business suffixes, include location names only when part of official name, use proper capitalization.\n",
    "- Be conservative: Only extract organizations you are confident about. When in doubt, exclude rather than include.\n",
    "\"\"\"\n",
    "\n",
    "ORGANIZATION_INFORMATION_SYSTEM_PROMPT = \"\"\"\n",
    "You extract facts ONLY about this organization: {organization}.\n",
    "Be conservative. If attribution is uncertain, exclude it.\n",
    "\n",
    "Rules (hard):\n",
    "- Include a fact only if its evidence explicitly names {organization}.\n",
    "- Do NOT infer missing details, do NOT paraphrase into new facts, do NOT fill gaps.\n",
    "- For official website, only include the domain name.\n",
    "- The official phone number must be the organization's primary official contact number.\n",
    "\n",
    "Address Parsing Rules:\n",
    "- ALWAYS parse comma-separated location strings into separate fields (city, state/region, country).\n",
    "- address_line1/line2/line3 are for STREET addresses only, NOT for city/state/country.\n",
    "- Country extraction is MANDATORY. Use ALL available information sources.\n",
    "- DO NOT leave country fields blank if ANY information suggests a country location.\n",
    "\"\"\"\n",
    "\n",
    "ORGANIZATION_INFORMATION_SYSTEM_PROMPT = \"\"\"\n",
    "You extract facts ONLY about this organization: {organization}.\n",
    "Be conservative. If attribution is uncertain, exclude it.\n",
    "\n",
    "Rules (hard):\n",
    "- Include a fact only if its evidence explicitly names {organization} OR uses an unambiguous pointer to it (same address/phone/URL).\n",
    "- If multiple facilities are on the page, ignore all others.\n",
    "- Do NOT infer missing details, do NOT fill gaps.\n",
    "- For official website, only include the domain name.\n",
    "- The official phone number must be the primary official contact number in E164 format.\n",
    "\n",
    "Address Parsing Rules:\n",
    "- ALWAYS parse comma-separated location strings into separate fields (city, state/region, country).\n",
    "- address_line1/line2/line3 are for STREET addresses ONLY.\n",
    "- Country extraction is MANDATORY.\n",
    "- DO NOT leave country blank if ANY information suggests a country location.\n",
    "\"\"\"\n",
    "\n",
    "FREE_FORM_SYSTEM_PROMPT = \"\"\"\n",
    "ROLE\n",
    "You are a specialized medical facility information extractor.\n",
    "\n",
    "TASK\n",
    "Extract verifiable facts about: `{organization}`\n",
    "\n",
    "CATEGORY DEFINITIONS\n",
    "- procedure: Clinical procedures, surgical operations, and medical interventions performed at the facility.\n",
    "- equipment: Physical medical devices, diagnostic machines, infrastructure, and utilities.\n",
    "- capability: Medical capabilities defining what level and types of clinical care the facility can deliver.\n",
    "\n",
    "EXTRACTION GUIDELINES\n",
    "- Only extract facts directly supported by the provided content.\n",
    "- Each fact should be self-contained and understandable without context.\n",
    "- No generic statements that could apply to any facility.\n",
    "\n",
    "CRITICAL REQUIREMENTS\n",
    "- All arrays can be empty if no relevant facts are found.\n",
    "- Do not include facts from general medical knowledge.\n",
    "\n",
    "EXAMPLE OUTPUT\n",
    "{{\n",
    "  \"procedure\": [\"Performs emergency cesarean sections\"],\n",
    "  \"equipment\": [\"Has Siemens SOMATOM Force dual-source CT scanner\"],\n",
    "  \"capability\": [\"Level II trauma center\", \"Joint Commission accredited\"]\n",
    "}}\n",
    "\n",
    "Respond ONLY with valid JSON. No markdown fences.\n",
    "\"\"\"\n",
    "\n",
    "MEDICAL_SPECIALTIES_SYSTEM_PROMPT = \"\"\"You are a medical specialty classifier.\n",
    "\n",
    "Target Facility: {organization}\n",
    "\n",
    "Map identified terms to EXACT specialty names (camelCase):\n",
    "internalMedicine, familyMedicine, pediatrics, cardiology, cardiacSurgery,\n",
    "generalSurgery, emergencyMedicine, gynecologyAndObstetrics, obstetricsAndMaternityCare,\n",
    "orthopedicSurgery, dentistry, ophthalmology, otolaryngology, dermatology, psychiatry,\n",
    "neurology, neurosurgery, radiology, pathology, anesthesia, infectiousDiseases,\n",
    "medicalOncology, surgicalOncology, nephrology, urology, gastroenterology, pulmonology,\n",
    "endocrinologyAndDiabetesAndMetabolism, rheumatology, hematology,\n",
    "physicalMedicineAndRehabilitation, criticalCareMedicine, plasticSurgery, vascularSurgery,\n",
    "transplantSurgery, neonatologyPerinatalMedicine, reproductiveEndocrinologyAndInfertility,\n",
    "hospiceAndPalliativeInternalMedicine, geriatricsInternalMedicine, publicHealth,\n",
    "socialAndBehavioralSciences, globalHealthAndInternationalHealth, orthodontics,\n",
    "maternalFetalMedicineOrPerinatology\n",
    "\n",
    "Be conservative — only predict specialties clearly mentioned or strongly implied.\n",
    "\n",
    "Respond ONLY with valid JSON:\n",
    "{{\"specialties\": [\"specialty1\", \"specialty2\"]}}\n",
    "\"\"\"\n",
    "\n",
    "class OrganizationExtractionOutput(BaseModel):\n",
    "    ngos: Optional[List[str]] = Field(default_factory=list)\n",
